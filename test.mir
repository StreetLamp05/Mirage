// Lexer Test File
// Exercises all token types for the Mirage lexer
// ** THIS FILE WAS GENERATED BY CLAUDE **
// but it seems like it tests all the tokens so I will trust :P 

/* multi-line comment */
/* nested /* comment */ still outer */

func main(args []string) -> int {
    // variables and types
    var x int = 5;
    var name = "hello\nworld";
    var _private = 42;
    const PI = 3.14;
    const BIG = 1e10;
    var hex_val = 0xFF;
    var bin_val = 0b1010;
    var foo_bar float32 = 2.5;
    var flag bool = true;
    var done = false;
    var b byte = 0;

    // type keywords
    var a int8 = 1;
    var c int16 = 2;
    var d int32 = 3;
    var e int64 = 4;
    var f uint8 = 5;
    var g uint16 = 6;
    var h uint32 = 7;
    var i uint64 = 8;
    var j float64 = 9.0;
    var k string = "test";

    // arithmetic operators
    x = 1 + 2 - 3 * 4 / 5 % 6;

    // comparison operators
    if x == 0 || x != 1 && x < 10 || x > 0 || x <= 5 || x >= 3 {
        x = 0;
    }

    // bitwise operators
    x = x & 0xFF | 0x0F ^ 0x01;
    x = ~x;
    x = x << 2;
    x = x >> 1;

    // assignment operators
    x += 1;
    x -= 1;
    x *= 2;
    x /= 2;
    x %= 3;
    x &= 0xFF;
    x |= 0x01;
    x ^= 0x0F;
    x <<= 1;
    x >>= 1;

    // increment/decrement
    x++;
    x--;

    // control flow
    if x > 3 {
        println("big");
    } else if x > 0 {
        println("small");
    } else {
        println("zero");
    }

    for i in range(10) {
        x += 1;
        if x > 50 {
            break;
        }
        continue;
    }

    while x > 0 {
        x -= 1;
    }

    match x {
        0 -> println("zero"),
        _ -> println("other"),
    }

    // special operators
    var nums []int = [1, 2, 3, 4, 5];
    var slice = nums[1..3];
    var inclusive = nums[1..=3];

    // struct, enum, mod, use, pub, spawn, unsafe, mut
    struct Point {
        x float,
        y float,
    }

    var p = Point { x: 1.0, y: 2.0 };
    var q = p.x;

    // question mark and arrow
    var result = doSomething()?;

    // scope resolution
    var color = Color::Red;

    // string with escapes
    var escaped = "tab\there\nnewline\r\0\\\"";

    // identifiers starting with keywords
    var return_value = 0;
    var format = "test";
    var interesting = true;

    // range with numbers (5..10 should be INT, DOT_DOT, INT)
    var r = 5..10;

    return 0;
}
